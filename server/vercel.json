{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["routes/**", "controller/**", "supabase/**", "*.ts"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.ts" }
  ],
  "env": {
    "NODE_OPTIONS": "--openssl-legacy-provider"
  },
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "devCommand": "bun run dev"
}
