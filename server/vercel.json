{
  "version": 2,
  "functions": {
    "server.ts": {
      "runtime": "vercel/node"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "server.ts" }
  ],
  "env": {
    "NODE_OPTIONS": "--openssl-legacy-provider"
  },
  "installCommand": "bun install",
  "buildCommand": "bun build server.ts",
  "devCommand": "bun start"
}
